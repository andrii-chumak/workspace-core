# ==============================================================================
# WORKSPACE CORE — BACKEND ENVIRONMENT VARIABLES CONFIGURATION (TEMPLATE)
# ==============================================================================
# Скопіюйте цей файл як '.env' у цю ж папку та заповніть реальними даними.
# Файл '.env' містить секрети й НЕ повинен потрапляти в Git!

# Базові налаштування Django
# ------------------------------------------------------------------------------
DEBUG=True
SECRET_KEY=django-insecure-local-development-dummy-key-change-me-in-production

# Налаштування підключення до бази даних PostgreSQL (для Docker-compose)
# ------------------------------------------------------------------------------
DB_NAME=workspace_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432